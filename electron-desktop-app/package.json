{
  "name": "woxverse-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for the Woxverse React workspace",
  "main": "main.cjs",
  "scripts": {
    "dev:renderer": "npm --prefix ../react-ts-app run dev -- --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "npm --prefix ../react-ts-app run build",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.woxverse.desktop",
    "productName": "Woxverse",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "preload.cjs"
    ],
    "extraMetadata": {
      "main": "main.cjs"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  }
}
